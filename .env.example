# TheHood optional provider configuration.
# Copy to .env only for local experiments. Never commit real credentials.

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ChatGPT Web bridge settings are usually generated with:
# node dist/cli/main.js mcp config --chatgpt-web
# THEHOOD_CHATGPT_WEB_COMMAND=
# THEHOOD_CHATGPT_WEB_MODEL_CONFIRMED=0
# THEHOOD_CHATGPT_WEB_CDP_URL=http://127.0.0.1:9222
# THEHOOD_CHATGPT_WEB_TIMEOUT_MS=300000
